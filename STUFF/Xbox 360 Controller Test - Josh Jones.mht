name=3DThe_Code></A>
<H2><SPAN class=3Dmw-headline>The Code </SPAN></H2>
<P>Most of this is taken directly from the samples in the <A=20
class=3D"external text"=20
title=3Dhttp://www.microsoft.com/downloads/details.aspx?FamilyId=3D1C8DC4=
51-2DBE-4ECC-8C57-C52EEA50C20A&amp;displaylang=3Den=20
href=3D"http://www.microsoft.com/downloads/details.aspx?FamilyId=3D1C8DC4=
51-2DBE-4ECC-8C57-C52EEA50C20A&amp;displaylang=3Den"=20
rel=3Dnofollow>DirectX SDK (October 2005)</A> </P>
<P>First you need the new header file: </P><PRE>#include =
&lt;XInput.h&gt; // For Xbox 360 Controllers
</PRE>
<P>You also need to include the Xinput.lib file for the linker or you'll =
get=20
funky linker errors. </P>
<P>Here is a handy define that we'll be using all over the place: =
</P><PRE>//! XInput handles up to 4 controllers
#define DXUT_MAX_CONTROLLERS 4
</PRE>
<P>Here is the structure that will hold all the status data for a =
controller:=20
</P><PRE>typedef struct DXUT_GAMEPAD_t
{
    // From XINPUT_GAMEPAD
    WORD    wButtons;
    BYTE    bLeftTrigger;
    BYTE    bRightTrigger;
    SHORT   sThumbLX;
    SHORT   sThumbLY;
    SHORT   sThumbRX;
    SHORT   sThumbRY;

    // Device properties
    XINPUT_CAPABILITIES caps;
    bool    bConnected; // If the controller is currently connected
    bool    bInserted;  // If the controller was inserted this frame
    bool    bRemoved;   // If the controller was removed this frame

    // Thumb stick values converted to range [-1,+1]
    float   fThumbRX;
    float   fThumbRY;
    float   fThumbLX;
    float   fThumbLY;

    // Left and right triggers as axis [0, 1]
    float   fTriggerL;
    float   fTriggerR;
	=09
    // Records which buttons were pressed this frame.
    // These are only set on the first frame that the button is pressed
    WORD    wPressedButtons;
    bool    bPressedLeftTrigger;
    bool    bPressedRightTrigger;

    // Last state of the buttons
    WORD    wLastButtons;
    bool    bLastLeftTrigger;
    bool    bLastRightTrigger;

} DXUT_GAMEPAD, *DXUT_GAMEPAD_PTR;
</PRE>
<P>Finally declare an array of 4 of these structures since you could =
potentially=20
have 4 controllers plugged in at once: </P><PRE>//! All of the Xinput =
Joysticks
DXUT_GAMEPAD m_XinputGamePads[DXUT_MAX_CONTROLLERS];
</PRE>
<P>Some more handy defines for the next function: </P><PRE>#define =
DXUT_GAMEPAD_TRIGGER_THRESHOLD      30
#define DXUT_INPUT_DEADZONE                 ( 0.24f * FLOAT(0x7FFF) )  =
// Default to 24% of the +/- 32767 range.  =20
                                                                       =
// This is a reasonable default value but can be altered if needed.
#define AXIS_THRESHOLD                      32767.0f
#define AXIS_TRIGGER_THRESHOLD              255.0f

#define DXUT_GAMEPAD_NUMBUTTONS             12
#define DXUT_GAMEPAD_NUMAXIS                6
#define DXUT_GAMEPAD_NUMHATS                1
#define DXUT_GAMEPAD_NUMBALLS               0
#define DXUT_GAMEPAD_NAME		    "XBOX 360 For Windows (Controller)"
</PRE>
<P>This is the function that will be called once per game loop, or =
update loop.=20
Here is how to use the function: </P>
<UL>
  <LI>dwPort is a number 0-3 that represents which "player" the =
controller is=20
  for.=20
  <LI>pGamePad is an index to one of the 4 DXUT_GAMEPAD structs we just =
created.=20

  <LI>bThumbstickDeadZone defines if you want the axis to utilize a dead =
zone.=20
  <LI>bSnapThumbstickToCardinals, if true, treats an analog stick like a =
D-pad.=20
  </LI></UL>
<P>Here is how I call this function in my update loop: </P><PRE>// Get =
the state of the Xbox 360 gamepads
for( DWORD iUserIndex=3D0; iUserIndex&lt;DXUT_MAX_CONTROLLERS; =
iUserIndex++ )
    DXUTGetGamepadState( iUserIndex, &amp;m_XinputGamePads[iUserIndex], =
true, false );
</PRE>
<P>The function itself: </P><PRE>HRESULT =
CJoystick_DirectX::DXUTGetGamepadState( DWORD dwPort, DXUT_GAMEPAD* =
pGamePad, bool bThumbstickDeadZone, bool bSnapThumbstickToCardinals )
{
    if( dwPort &gt;=3D DXUT_MAX_CONTROLLERS ||&nbsp;!pGamePad )
	return E_FAIL;

    if(!m_bUsingXbox360Interface)
	return S_OK;

    static LPXINPUTGETSTATE        s_pXInputGetState        =3D NULL;
    static LPXINPUTGETCAPABILITIES s_pXInputGetCapabilities =3D NULL;

    if(&nbsp;!s_pXInputGetState ||&nbsp;!s_pXInputGetCapabilities )
    {
	LPSTR wszPath =3D new CHAR[MAX_PATH];
	if( GetSystemDirectory( wszPath, MAX_PATH ) )
	{
	    char* temp =3D "\\";
	    StringCchCat( wszPath, MAX_PATH, temp );
	    StringCchCat( wszPath, MAX_PATH, XINPUT_DLL );
	    HINSTANCE hInst =3D LoadLibrary( wszPath );
	    if( hInst )=20
	    {
	        s_pXInputGetState =3D (LPXINPUTGETSTATE)GetProcAddress( hInst, =
"XInputGetState" );
		s_pXInputGetCapabilities =3D (LPXINPUTGETCAPABILITIES)GetProcAddress( =
hInst, "XInputGetCapabilities" );
	    }
	}
	delete [] wszPath;
    }
    if( s_pXInputGetState =3D=3D NULL )
	return E_FAIL;

    XINPUT_STATE InputState;
    DWORD dwResult =3D s_pXInputGetState( dwPort, &amp;InputState );

    // Track insertion and removals
    BOOL bWasConnected   =3D pGamePad-&gt;bConnected;
    pGamePad-&gt;bConnected =3D (dwResult =3D=3D ERROR_SUCCESS);
    pGamePad-&gt;bRemoved   =3D (  bWasConnected =
&amp;&amp;&nbsp;!pGamePad-&gt;bConnected );
    pGamePad-&gt;bInserted  =3D (&nbsp;!bWasConnected &amp;&amp;  =
pGamePad-&gt;bConnected );

    if(pGamePad-&gt;bRemoved)
	std::cout &lt;&lt; "Removed Xbox 360 Gamepad: Player " &lt;&lt; =
dwPort+1 &lt;&lt; std::endl;

    // Don't update rest of the state if not connected
    if(&nbsp;!pGamePad-&gt;bConnected )
	return S_OK;

    // Store the capabilities of the device
    if( pGamePad-&gt;bInserted )
    {
	std::cout &lt;&lt; "Found Xbox 360 Gamepad: Assigning player " &lt;&lt; =
dwPort+1 &lt;&lt; std::endl;

	ZeroMemory( pGamePad, sizeof(DXUT_GAMEPAD) );
	pGamePad-&gt;bConnected =3D true;
	pGamePad-&gt;bInserted  =3D true;
	if( s_pXInputGetCapabilities )
	    s_pXInputGetCapabilities( dwPort, XINPUT_DEVTYPE_GAMEPAD, =
&amp;pGamePad-&gt;caps );
    }

    // Copy gamepad to local structure (assumes that XINPUT_GAMEPAD at =
the front in CONTROLER_STATE)
    memcpy( pGamePad, &amp;InputState.Gamepad, sizeof(XINPUT_GAMEPAD) );

    if( bSnapThumbstickToCardinals )
    {
	// Apply deadzone to each axis independently to slightly snap to =
up/down/left/right
	if( pGamePad-&gt;sThumbLX &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbLX &gt; -DXUT_INPUT_DEADZONE )
	    pGamePad-&gt;sThumbLX =3D 0;
	if( pGamePad-&gt;sThumbLY &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbLY &gt; -DXUT_INPUT_DEADZONE )=20
	    pGamePad-&gt;sThumbLY =3D 0;
	if( pGamePad-&gt;sThumbRX &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbRX &gt; -DXUT_INPUT_DEADZONE )
	    pGamePad-&gt;sThumbRX =3D 0;
	if( pGamePad-&gt;sThumbRY &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbRY &gt; -DXUT_INPUT_DEADZONE )=20
	    pGamePad-&gt;sThumbRY =3D 0;
    }
    else if( bThumbstickDeadZone )
    {
	// Apply deadzone if centered
	if( (pGamePad-&gt;sThumbLX &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbLX &gt; -DXUT_INPUT_DEADZONE) &amp;&amp;=20
	    (pGamePad-&gt;sThumbLY &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbLY &gt; -DXUT_INPUT_DEADZONE) )=20
	{=09
	    pGamePad-&gt;sThumbLX =3D 0;
	    pGamePad-&gt;sThumbLY =3D 0;
	}
	if( (pGamePad-&gt;sThumbRX &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbRX &gt; -DXUT_INPUT_DEADZONE) &amp;&amp;=20
	    (pGamePad-&gt;sThumbRY &lt; DXUT_INPUT_DEADZONE &amp;&amp; =
pGamePad-&gt;sThumbRY &gt; -DXUT_INPUT_DEADZONE) )=20
	{
	    pGamePad-&gt;sThumbRX =3D 0;
	    pGamePad-&gt;sThumbRY =3D 0;
	}
    }

    // Convert [-1,+1] range
    pGamePad-&gt;fThumbLX =3D pGamePad-&gt;sThumbLX / AXIS_THRESHOLD;
    pGamePad-&gt;fThumbLY =3D pGamePad-&gt;sThumbLY / AXIS_THRESHOLD;
    pGamePad-&gt;fThumbRX =3D pGamePad-&gt;sThumbRX / AXIS_THRESHOLD;
    pGamePad-&gt;fThumbRY =3D pGamePad-&gt;sThumbRY / AXIS_THRESHOLD;

    // Convert to [0, 1] range
    pGamePad-&gt;fTriggerL =3D pGamePad-&gt;bLeftTrigger / =
AXIS_TRIGGER_THRESHOLD;
    pGamePad-&gt;fTriggerR =3D pGamePad-&gt;bRightTrigger / =
AXIS_THRESHOLD;

    // Get the boolean buttons that have been pressed since the last =
call.=20
    // Each button is represented by one bit.
    pGamePad-&gt;wPressedButtons =3D ( pGamePad-&gt;wLastButtons ^ =
pGamePad-&gt;wButtons ) &amp; pGamePad-&gt;wButtons;
    pGamePad-&gt;wLastButtons    =3D pGamePad-&gt;wButtons;

    // Figure out if the left trigger has been pressed or released
    bool bPressed =3D ( pGamePad-&gt;bLeftTrigger &gt; =
DXUT_GAMEPAD_TRIGGER_THRESHOLD );
    pGamePad-&gt;bPressedLeftTrigger =3D ( bPressed =
)&nbsp;?&nbsp;!pGamePad-&gt;bLastLeftTrigger&nbsp;: false;
    pGamePad-&gt;bLastLeftTrigger =3D bPressed;

    // Figure out if the right trigger has been pressed or released
    bPressed =3D ( pGamePad-&gt;bRightTrigger &gt; =
DXUT_GAMEPAD_TRIGGER_THRESHOLD );
    pGamePad-&gt;bPressedRightTrigger =3D ( bPressed =
)&nbsp;?&nbsp;!pGamePad-&gt;bLastRightTrigger&nbsp;: false;
    pGamePad-&gt;bLastRightTrigger =3D bPressed;

    m_pJoysticks[dwPort];

    return S_OK;
}
</PRE>
<P>That magical function takes care of almost everything. To use the =
joystick=20
you just make checks against that structure. Here is an example used for =
testing=20
to see if a button is pressed down or not. For convenience I use numbers =
to=20
reference my buttons, but you can do it however you want. </P><PRE>// =
Xinput controllers
if( (index &gt;=3D 0) &amp;&amp; (index &lt;=3D 3) )
{
    if( m_XinputGamePads[index].bConnected )
    {
	switch( button )=20
	{
	case 0:  // A Button
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_A)&nbsp;? true&nbsp;: false );

	case 1:  // B Button
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_B)&nbsp;? true&nbsp;: false );

	case 2:  // X Button
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_X)&nbsp;? true&nbsp;: false );

	case 3:  // Y Button
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_Y)&nbsp;? true&nbsp;: false );

	case 4:  // Left shoulder
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_LEFT_SHOULDER)&nbsp;? true&nbsp;: false );

	case 5:  // Right shoulder
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_RIGHT_SHOULDER)&nbsp;? true&nbsp;: false );

	case 6:  // Back
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_BACK)&nbsp;? true&nbsp;: false );

	case 7:  // Start
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_START)&nbsp;? true&nbsp;: false );

	case 8:  // Left thumb
	    return((m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_LEFT_THUMB)&nbsp;? true&nbsp;: false );

	case 9:  // Right thumb
	    return( (m_XinputGamePads[index].wButtons &amp; =
XINPUT_GAMEPAD_RIGHT_THUMB)&nbsp;? true&nbsp;: false );

	case 10: // Left trigger
	    return( (m_XinputGamePads[index].bLeftTrigger &gt;=3D =
DXUT_GAMEPAD_TRIGGER_THRESHOLD)&nbsp;? true&nbsp;: false );

	case 11: // Right rigger
	    return( (m_XinputGamePads[index].bRightTrigger &gt;=3D =
DXUT_GAMEPAD_TRIGGER_THRESHOLD)&nbsp;? true&nbsp;: false );
	}
    }
    else
	return false;
</PRE>
<P>An example of a function that contains this logic would be similar to =
this:=20
</P><PRE>// Check for the first gamepad's A button
// First parameter is the gamepad index, the second is the button to =
check
if(isButtonPressed(0, 0))
    playerJumped();  // Some made up example function
</PRE><A name=3DThanks></A>
